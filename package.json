{
  "name": "@atomichub/atomicassets",
  "description": "JavaScript/TypeScript SDK for the AtomicAssets NFT standard on Antelope chains: read NFT data, serialize attribute data, and build v2 contract actions",
  "keywords": [
    "atomicassets",
    "atomicmarket",
    "atomichub",
    "wax",
    "antelope",
    "eosio",
    "nft",
    "blockchain",
    "sdk"
  ],
  "author": "AtomicHub",
  "homepage": "https://github.com/atomicassets/atomicassets-sdk",
  "bugs": {
    "url": "https://github.com/atomicassets/atomicassets-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atomicassets/atomicassets-sdk.git"
  },
  "license": "MIT",
  "sideEffects": false,
  "version": "2.0.0",
  "engines": {
    "node": ">=20"
  },
  "main": "build/index.cjs",
  "module": "build/index.mjs",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./build/index.d.mts",
        "default": "./build/index.mjs"
      },
      "require": {
        "types": "./build/index.d.ts",
        "default": "./build/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "build/",
    "NOTICE",
    "licenses/"
  ],
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "lint": "eslint .",
    "pretest": "tsup",
    "test": "mocha -r ts-node/register test/**/*.test.ts",
    "prepare": "tsup",
    "prepack": "tsup"
  },
  "devDependencies": {
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^22.0.0",
    "chai": "^4.4.1",
    "eslint": "^9.17.0",
    "mocha": "^11.0.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.59.0"
  }
}
